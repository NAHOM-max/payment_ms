datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "go run github.com/steebchen/prisma-client-go"
  output   = "../infrastructure/db/prisma"
}

enum PaymentStatus {
  INITIATED
  SUCCESSFUL
  FAILED
  CANCELED
  REFUND_REQUESTED
}

model payment {
  id         String        @id @default(uuid())
  customerId String
  orderId    String
  workflowId String
  amount     Float
  status     PaymentStatus
  createdAt  DateTime
  updatedAt  DateTime

  @@index([workflowId])
}

model inboxEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  eventType String
  payload   Json     @db.JsonB
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inbox_events")
}
