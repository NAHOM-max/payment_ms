datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "go run github.com/steebchen/prisma-client-go"
  output   = "../infrastructure/db/prisma"
}

enum PaymentStatus {
  INITIATED
  SUCCESSFUL
  FAILED
  CANCELED
}

model payment {
  id         String        @id @default(uuid())
  customerId String
  orderId    String
  workflowId String
  amount     Float
  status     PaymentStatus
  createdAt  DateTime
  updatedAt  DateTime

  @@index([workflowId])
}
